{{- $posts := where (where site.RegularPages "Section" "blog") "Params.deprecated_since" nil -}}
{{- $now := now -}}
<rss version="2.0"
    xmlns:content="http://purl.org/rss/1.0/modules/content/"
    xmlns:dc="http://purl.org/dc/elements/1.1/"
    xmlns:atom="http://www.w3.org/2005/Atom"
>
    <channel>
        <title>{{ site.Params.rssTitle | default site.Title | plainify }}</title>
        <link>{{ "/" | absURL }}</link>
        <description>{{ site.Params.description | plainify }}</description>
        <pubDate>{{ $now.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
        <atom:link href="{{ "rss.xml" | absURL }}" rel="self" type="application/rss+xml" />
        {{ with index $posts 0 }}
        <lastBuildDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
        {{ end }}
        {{ range $posts }}
            {{- if le (.Date.Format "2006-01-02") ($now.Format "2006-01-02") }}
        <item>
            <title>{{ .Title | plainify }}</title>
            <link>{{ .Permalink }}</link>
            <description>{{ with .Params.perex }}{{ . | plainify }}{{ end }}</description>
            <guid isPermaLink="false">{{ .Permalink }}</guid>
            <dc:creator>{{ site.Params.author | default site.Title }}</dc:creator>
            <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
        </item>
            {{- end -}}
        {{ end }}
    </channel>
</rss>
